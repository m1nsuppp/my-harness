{
  "permissions": {
    "deny": [
      "Read(**/.env*)",
      "Edit(**/.env*)",
      "Bash(cat */.env*)",
      "Bash(cat .env*)"
    ],
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "Task(*)",
      "mcp__*"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/hooks/skill-eval.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'INPUT=$(cat); if echo \"$INPUT\" | jq -e \".stop_hook_active\" >/dev/null 2>&1; then exit 0; fi; if ! git -C \"$CLAUDE_PROJECT_DIR\" status --porcelain 2>/dev/null | grep -qE \"\\.(ts|tsx|js|jsx|mjs|cjs)$\"; then exit 0; fi; echo \"{\\\"decision\\\":\\\"block\\\",\\\"reason\\\":\\\"verify-code 스킬을 호출하여 코드를 검증하세요.\\\"}\"'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "effortLevel": "high"
}
